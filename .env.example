# ============================================================
# SpatialChat Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# LLM Provider
# Set ONE of the two API keys below. The provider is auto-detected
# from whichever key you provide. If both are set, LLM_PROVIDER
# controls which one is used.
#
# LLM_PROVIDER=openai          # Optional: force a provider
# LLM_MODEL=gpt-4o             # Optional: override the default model
# SUB_AGENT_MODEL=gpt-4o-mini  # Optional: cheaper model for sub-agents (saves ~70% on tokens)

# Option A: OpenAI (default model: gpt-4o)
OPENAI_API_KEY=sk-your-key-here

# Option B: Anthropic (default model: claude-sonnet-4-20250514)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# LangSmith Observability
# Sign up at https://smith.langchain.com (free tier works)
# Or self-host: https://docs.smith.langchain.com/self_hosting
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=spatialchat
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# Data
DATA_DIR=./data/cache
# Max datasets to hold in memory at once
MAX_LOADED_DATASETS=3

# Vector Database (RAG)
# Directory for persistent ChromaDB storage (gene expression embeddings)
# VECTORDB_DIR=./data/vectordb

# App
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
